            "keywords": [
                "ERROR",
                "ERR",
                "CRITICAL",
                "EXCEPTION",
                "TRACEBACK",
                "FATAL"
            ],
            "severity": "critical"
        },
        {
            "name": "WARNING",
            "category": "Ostrzeżenie",
            "keywords": [
                "WARNING",
                "WARN"
            ],
            "severity": "warning"
        },
        {
            "name": "FAILED_OPERATION",
            "category": "Błąd krytyczny",
            "keywords": [
                "FAILED",
                "FAIL"
            ],
            "severity": "critical"
        },
        {
            "name": "TIMEOUT",
            "category": "Inne",
            "keywords": [
                "TIMEOUT"
            ],
            "severity": "warning"
        },
        {
            "name": "CONNECTION_LOST",
            "category": "Problem z połączeniem",
